---
import { marked } from "marked";
import { formatMemoDate, formatMemoTime, getAttachmentUrl, type MemoAttachment } from "../lib/fetchMemos";
import { Icon } from "astro-icon/components";
import TagPill from "./TagPill.astro";

export interface Props {
	content: string;
	displayTime: string;
	/** Show full date (true) or short time only (false) */
	showFullDate?: boolean;
	/** Attachment files from the memo */
	attachments?: MemoAttachment[];
	/** Location info */
	location?: {
		placeholder: string;
		latitude: number;
		longitude: number;
	};
	/** Tags extracted from memo */
	tags?: string[];
}

const { content, displayTime, showFullDate = true, attachments = [], location, tags = [] } = Astro.props;

// Configure marked for safe, synchronous rendering
marked.setOptions({ async: false, breaks: true, gfm: true });

let displayContent = content;
if (tags && tags.length > 0) {
	tags.forEach(tag => {
		// Escape special characters in tag
		const escapedTag = tag.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
		// Match the exact tag: '#' followed by the tag, starting word boundary (implied by #), ending with space, end of line, or punctuation
		const tagRegex = new RegExp(`#${escapedTag}(?:\\s+|$)`, 'g');
		displayContent = displayContent.replace(tagRegex, ' ');
	});
	displayContent = displayContent.trim();
}

const htmlContent = marked.parse(displayContent) as string;
const dateLabel = showFullDate ? formatMemoDate(displayTime) : formatMemoTime(displayTime);

// Filter image attachments
const imageAttachments = attachments.filter(att => att.type.startsWith("image/"));
---

<div class="relative pl-6 border-l border-neutral-300 dark:border-neutral-700 w-full group moment-card" data-tags={tags.join(",")}>
	<!-- Timeline indicator -->
	<div class="absolute left-[-7.5px] top-1.5 flex items-center justify-center w-4 h-4">
		<!-- Mask to hide the timeline line underneath -->
		<div class="absolute w-full h-full bg-white dark:bg-neutral-900 rounded-full scale-[1.3]"></div>
		<!-- The actual icon -->
		<Icon name="lucide:feather" class="relative z-10 w-4 h-4 text-[#bc152d] transition-all duration-300 group-hover:scale-125 group-hover:drop-shadow-[0_0_8px_rgba(188,21,45,0.8)] group-hover:text-[#e01936]" />
	</div>
	
	<!-- Timestamp -->
	<span class="font-mono text-xs text-[#bc152d] opacity-90 mb-2 block tracking-widest">
		{dateLabel}
	</span>

	<!-- Rendered Markdown content -->
	<div
		class="prose prose-sm prose-neutral dark:prose-invert max-w-none
			text-neutral-600 dark:text-neutral-400 leading-relaxed m-0
			prose-p:my-2 prose-a:text-[#bc152d] prose-a:no-underline hover:prose-a:underline
			prose-code:text-xs prose-code:bg-neutral-100 prose-code:dark:bg-neutral-800 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded-none
			prose-pre:bg-neutral-50 prose-pre:dark:bg-neutral-800/80 prose-pre:border prose-pre:border-neutral-200 prose-pre:dark:border-neutral-700 prose-pre:rounded-none
			prose-img:rounded-none prose-img:border prose-img:border-neutral-200 prose-img:dark:border-neutral-700"
		set:html={htmlContent}
	/>

	<!-- Tags -->
	{tags.length > 0 && (
		<div class="mt-4 mb-6 flex flex-wrap gap-3">
			{tags.map((tag: string) => (
				<TagPill tag={tag} href={`?tag=${encodeURIComponent(tag)}`} />
			))}
		</div>
	)}

	<!-- Image Attachments -->
	{imageAttachments.length > 0 && (
		<div class:list={[
			"mt-4 gap-2 w-full",
			imageAttachments.length === 1 ? "" : "grid",
			imageAttachments.length === 2 ? "grid-cols-2" : "",
			imageAttachments.length >= 3 ? "grid-cols-3" : ""
		]}>
			{imageAttachments.map((att) => (
				imageAttachments.length === 1 ? (
					<div class="inline-flex overflow-hidden border border-neutral-200 dark:border-neutral-800 hover:border-[#bc152d] dark:hover:border-[#bc152d] transition-colors cursor-zoom-in group/img bg-transparent max-w-full sm:max-w-[80%] md:max-w-[75%] lg:max-w-[66%]">
						<img
							src={getAttachmentUrl(att.name, att.filename)}
							alt={att.filename}
							data-lightbox={getAttachmentUrl(att.name, att.filename)}
							class="!m-0 w-full h-auto max-h-[36rem] object-cover block transition-transform duration-300 group-hover/img:scale-[1.03]"
							loading="lazy"
						/>
					</div>
				) : (
					<div class="relative overflow-hidden border border-neutral-200 dark:border-neutral-800 hover:border-[#bc152d] dark:hover:border-[#bc152d] transition-colors cursor-zoom-in group/img bg-transparent aspect-square w-full">
						<img
							src={getAttachmentUrl(att.name, att.filename)}
							alt={att.filename}
							data-lightbox={getAttachmentUrl(att.name, att.filename)}
							class="!m-0 absolute inset-0 w-full h-full object-cover block transition-transform duration-300 group-hover/img:scale-[1.03]"
							loading="lazy"
						/>
					</div>
				)
			))}
		</div>
	)}

	<!-- Location -->
	{location && location.placeholder && (
		<div class="mt-3 flex items-center gap-1.5 text-xs text-neutral-400 dark:text-neutral-500 font-mono tracking-wider">
			<Icon name="lucide:map-pin" class="w-3.5 h-3.5 text-[#bc152d] opacity-70 flex-shrink-0" />
			<span>{location.placeholder}</span>
		</div>
	)}
</div>
