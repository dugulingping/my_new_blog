---
const today = new Date();
import { Icon } from "astro-icon/components";
---

<footer class="py-16 px-4 mt-10 border-t border-neutral-100 dark:border-neutral-800/50 transition-colors duration-300">
	<div class="flex flex-col items-center gap-6">
		<!-- The "Seal" Component -->
		<div class="w-10 h-10 bg-[#bc152d] flex items-center justify-center shadow-sm">
			<Icon name="lucide:pen-tool" class="w-5 h-5 text-white" />
		</div>

		<!-- Copyright -->
		<p class="font-body text-[10px] tracking-[0.3em] text-neutral-400 dark:text-neutral-500 uppercase">
			独孤伶俜 &copy; {today.getFullYear()}
		</p>
	</div>
</footer>
