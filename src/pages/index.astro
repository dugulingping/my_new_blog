---
import { Image } from "astro:assets";
import LogoLight from "../assets/theme/logo-0.png";
import LogoDark from "../assets/theme/logo-1.png";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import { MEMOS_API_BASE } from "../lib/fetchMemos";
import { Icon } from "astro-icon/components";
---

<!DOCTYPE html>
<html lang="zh-cn">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body
		class="bg-white dark:bg-neutral-900 text-neutral-800 dark:text-neutral-200 transition-colors duration-300"
	>
		<Header />
		<main
			class="mx-auto max-w-4xl px-4 py-10 font-body relative overflow-hidden"
		>
			<!-- Background Asymmetric Element removed to retain total clarity -->

			<div
				class="flex flex-col md:flex-row items-center gap-6 md:gap-10 mb-24 mt-12 relative z-10 md:pl-6"
			>
				<!-- Red Vertical Stroke Accent -->
				<div
					class="absolute left-0 top-0 bottom-4 w-px bg-gradient-to-b from-[#bc152d] via-[#bc152d]/50 to-transparent shadow-[0_0_8px_rgba(188,21,45,0.4)] hidden md:block"
				>
				</div>

				<!-- Logo -->
				<div class="flex-shrink-0 w-48 md:w-64">
					<a
						href="/"
						class="relative block transition-transform duration-500 hover:-translate-y-1 group"
					>
						<!-- Light mode logo -->
						<Image
							src={LogoLight}
							alt={SITE_TITLE}
							class="theme-light-only w-full object-cover m-0 transition-transform duration-700 group-hover:scale-105"
						/>
						<!-- Dark mode logo -->
						<Image
							src={LogoDark}
							alt={SITE_TITLE}
							class="theme-dark-only w-full object-cover m-0 transition-transform duration-700 group-hover:scale-105"
						/>
					</a>
				</div>

				<div class="flex-grow text-left w-full mt-6 md:mt-24 lg:mt-32">
					<div
						class="text-xs text-neutral-500 font-mono text-left mb-2"
					>
						// OP: BG9JYT | 73
					</div>
					<h2
						class="font-headline text-xl md:text-2xl font-normal tracking-widest text-neutral-800 dark:text-neutral-200 mb-4 flex items-center"
					>
						算尽方寸，波传寰宇
					</h2>
					<p
						class="text-sm text-neutral-400 leading-relaxed max-w-lg tracking-wider mt-4 mb-8 text-left"
					>
						这里是 独孤伶俜 (BG9JYT)
						的数字自留地。我将严谨写进底稿，将浪漫寄予天线，将理想编码成序。
					</p>

					<div
						class="flex flex-wrap items-center justify-start gap-4 md:gap-8 mt-4 relative z-20"
					>
						<div
							class="flex flex-col sm:flex-row items-start justify-start gap-4 w-full md:w-auto"
						>
							<a
								href="/blog"
								class="inline-flex w-full sm:w-auto justify-center items-center gap-3 px-6 py-2.5 bg-[#bc152d] text-white font-medium rounded-none hover:bg-[#a01226] transition-colors shadow-sm no-underline uppercase tracking-widest text-sm group"
							>
								<Icon
									name="lucide:arrow-right"
									class="w-4 h-4 transform group-hover:translate-x-1 transition-transform"
								/>
								阅读文章
							</a>
							<a
								href="/about"
								class="inline-flex w-full sm:w-auto justify-center items-center px-6 py-2.5 bg-transparent text-neutral-900 dark:text-white font-medium rounded-none border border-neutral-900 dark:border-white hover:opacity-70 transition-opacity duration-300 no-underline uppercase tracking-widest text-sm"
							>
								了解更多
							</a>
						</div>

						<!-- Social Links -->
						<div
							class="flex items-center gap-5 text-neutral-400 mt-4 md:mt-0"
						>
							<!-- <a
								href="https://m.webtoo.ls/@astro"
								target="_blank"
								class="hover:text-[#bc152d] dark:hover:text-[#ffb3b1] transition-colors relative group"
							>
								<span class="sr-only"
									>在 Mastodon 上关注 Astro</span
								>
								<Icon
									name="simple-icons:mastodon"
									class="w-5 h-5"
								/>
							</a> -->
							<!-- <a
								href="https://twitter.com/astrodotbuild"
								target="_blank"
								class="hover:text-[#bc152d] dark:hover:text-[#ffb3b1] transition-colors relative group"
							>
								<span class="sr-only"
									>在 Twitter 上关注 Astro</span
								>
								<Icon name="simple-icons:x" class="w-5 h-5" />
							</a> -->
							<a
								href="https://github.com/dugulingping"
								target="_blank"
								class="hover:text-[#bc152d] dark:hover:text-[#ffb3b1] transition-colors relative group"
							>
								<span class="sr-only"
									>访问 dugulingping 的 GitHub 仓库</span
								>
								<Icon
									name="simple-icons:github"
									class="w-5 h-5"
								/>
							</a>
						</div>
					</div>
				</div>
			</div>

			<div
				class="prose prose-neutral dark:prose-invert max-w-none mx-auto lg:max-w-3xl space-y-12"
			>
				<section
					class="border-t border-neutral-200 dark:border-neutral-800 pt-8 mt-12"
				>
					<h2 class="text-2xl font-bold mb-8 flex items-center gap-2">
						<Icon
							name="lucide:book-open"
							class="w-6 h-6 text-[#bc152d]"
						/>
						碎片随笔 / Moments
					</h2>

					<!-- Loading skeleton -->
					<div id="home-memos-loading" class="flex flex-col gap-6 mt-4">
						{[...Array(3)].map(() => (
							<div class="relative pl-6 border-l border-neutral-200 dark:border-neutral-800 animate-pulse">
								<div class="h-3 w-28 bg-neutral-200 dark:bg-neutral-700 rounded mb-3"></div>
								<div class="h-4 w-full bg-neutral-100 dark:bg-neutral-800 rounded mb-2"></div>
								<div class="h-4 w-3/4 bg-neutral-100 dark:bg-neutral-800 rounded"></div>
							</div>
						))}
					</div>

					<!-- Cards populated by JS -->
					<div id="home-memos-container" class="hidden flex flex-col gap-6 mt-4"></div>

					<!-- View All Link -->
					<div class="mt-8 text-right">
						<a
							href="/moments"
							class="inline-flex items-center gap-2 text-sm font-mono text-neutral-500 hover:text-[#bc152d] dark:hover:text-[#ffb3b1] transition-colors tracking-widest no-underline group"
						>
							查看全部动态
							<Icon
								name="lucide:arrow-right"
								class="w-3.5 h-3.5 transform group-hover:translate-x-1 transition-transform"
							/>
						</a>
					</div>
				</section>

				<section
					class="mt-12 p-6 bg-neutral-50 dark:bg-neutral-800/50 rounded-none border border-neutral-200 dark:border-neutral-800 relative z-0 overflow-hidden"
				>
					<div
						class="absolute inset-0 z-[-1] opacity-[0.05] dark:opacity-[0.05] pointer-events-none bg-[linear-gradient(to_right,#000_1px,transparent_1px),linear-gradient(to_bottom,#000_1px,transparent_1px)] dark:bg-[linear-gradient(to_right,#fff_1px,transparent_1px),linear-gradient(to_bottom,#fff_1px,transparent_1px)] bg-[size:16px_16px]"
					>
					</div>
					<h3 class="text-xl font-bold mb-6 mt-0">
						底层驱动 / Tech Stack
					</h3>
					<ul
						class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-6 mb-0 pl-0 list-none text-sm text-neutral-600 dark:text-neutral-400"
					>
						<li class="flex items-start">
							<span class="text-[#bc152d] font-mono mr-2"
								>&gt;</span
							><span
								><strong
									class="text-neutral-900 dark:text-neutral-200"
									>Astro 驱动</strong
								>：零 JS 注入，并利用 View Transitions
								提供流畅的页面平滑过渡。</span
							>
						</li>
						<li class="flex items-start">
							<span class="text-[#bc152d] font-mono mr-2"
								>&gt;</span
							><span
								><strong
									class="text-neutral-900 dark:text-neutral-200"
									>边缘计算</strong
								>：依托 Cloudflare，让数据随电波瞬息而至。</span
							>
						</li>
						<li class="flex items-start">
							<span class="text-[#bc152d] font-mono mr-2"
								>&gt;</span
							><span
								><strong
									class="text-neutral-900 dark:text-neutral-200"
									>原子化美学</strong
								>：利用 Tailwind CSS 和 Typography
								插件，勾勒深色模式下的视觉秩序。</span
							>
						</li>
						<li class="flex items-start">
							<span class="text-[#bc152d] font-mono mr-2"
								>&gt;</span
							><span
								><strong
									class="text-neutral-900 dark:text-neutral-200"
									>Markdown / MDX / Memos</strong
								> — 所见即所得的高效书写体验。</span
							>
						</li>
					</ul>
				</section>
			</div>

			<!-- 移除多余的默认样板文案 -->
		</main>
		<Footer />

		<!-- marked.js for client-side markdown rendering -->
		<script src="https://cdn.jsdelivr.net/npm/marked@12/marked.min.js"></script>

		<script is:inline define:vars={{ MEMOS_API_BASE }}>
			function formatDate(iso) {
				const d = new Date(iso);
				return `${d.getFullYear()}年${d.getMonth()+1}月${d.getDate()}日 ${String(d.getHours()).padStart(2,"0")}:${String(d.getMinutes()).padStart(2,"0")}`;
			}
			function getAttachmentUrl(name, filename) {
				return `${MEMOS_API_BASE}/file/${name}/${encodeURIComponent(filename)}`;
			}
			function renderContent(content, tags) {
				let text = content;
				(tags||[]).forEach(tag => {
					const esc = tag.replace(/[.*+?^${}()|[\]\\]/g,"\\$&");
					text = text.replace(new RegExp(`#${esc}(?:\\s+|$)`,"g")," ");
				});
				if (typeof marked !== "undefined") {
					marked.setOptions({ breaks: true, gfm: true });
					return marked.parse(text.trim());
				}
				return `<p>${text.trim().replace(/\n/g,"<br>")}</p>`;
			}

			function buildCardHTML(memo) {
				const tags = memo.tags || [];
				const attachments = (memo.attachments || []).filter(a => a.type && a.type.startsWith("image/"));
				const tagsHTML = tags.length > 0 ? `<div class="mt-3 flex flex-wrap gap-2">${tags.map(t=>`<a href="/moments?tag=${encodeURIComponent(t)}" class="text-xs font-mono text-neutral-500 dark:text-neutral-400 bg-neutral-100 dark:bg-neutral-800 px-2 py-1 rounded-sm no-underline hover:text-[#bc152d] tracking-widest">[ ${t} ]</a>`).join("")}</div>` : "";
				const imagesHTML = attachments.length > 0 ? (() => {
					const gridClass = attachments.length === 1 ? "" : attachments.length === 2 ? "grid grid-cols-2 gap-2" : "grid grid-cols-3 gap-2";
					return `<div class="mt-3 ${gridClass}">${attachments.map(att => {
						const src = getAttachmentUrl(att.name, att.filename);
						return attachments.length === 1
							? `<div class="inline-flex overflow-hidden border border-neutral-200 dark:border-neutral-800 hover:border-[#bc152d] transition-colors cursor-zoom-in max-w-[80%]"><img src="${src}" alt="${att.filename}" data-lightbox="${src}" class="!m-0 w-full h-auto max-h-80 object-cover" loading="lazy"/></div>`
							: `<div class="relative overflow-hidden border border-neutral-200 dark:border-neutral-800 hover:border-[#bc152d] transition-colors cursor-zoom-in aspect-square"><img src="${src}" alt="${att.filename}" data-lightbox="${src}" class="!m-0 absolute inset-0 w-full h-full object-cover" loading="lazy"/></div>`;
					}).join("")}</div>`;
				})() : "";
				const locationHTML = memo.location?.placeholder ? `<div class="mt-2 text-xs text-neutral-400 font-mono">📍 ${memo.location.placeholder}</div>` : "";
				return `<div class="relative pl-6 border-l border-neutral-300 dark:border-neutral-700 w-full group">
					<div class="absolute left-[-7.5px] top-1.5 flex items-center justify-center w-4 h-4">
						<div class="absolute w-full h-full bg-white dark:bg-neutral-900 rounded-full scale-[1.3]"></div>
						<svg class="relative z-10 w-4 h-4 text-[#bc152d]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
					</div>
					<span class="font-mono text-xs text-[#bc152d] opacity-90 mb-2 block tracking-widest">${formatDate(memo.displayTime)}</span>
					<div class="prose prose-sm prose-neutral dark:prose-invert max-w-none text-neutral-600 dark:text-neutral-400 leading-relaxed m-0 prose-p:my-2 prose-a:text-[#bc152d] prose-a:no-underline">${renderContent(memo.content, tags)}</div>
					${tagsHTML}${imagesHTML}${locationHTML}
				</div>`;
			}

			async function initHomeMemos() {
				const loading = document.getElementById("home-memos-loading");
				const container = document.getElementById("home-memos-container");
				if (!loading || !container) return;

				try {
					const res = await fetch(`${MEMOS_API_BASE}/api/v1/memos?filter=visibility=="PUBLIC"&pageSize=5`);
					if (!res.ok) throw new Error(`HTTP ${res.status}`);
					const data = await res.json();
					const memos = (data.memos || []).sort((a, b) => new Date(b.displayTime) - new Date(a.displayTime));

					loading.classList.add("hidden");
					if (memos.length > 0) {
						container.innerHTML = memos.map(buildCardHTML).join("");
						container.classList.remove("hidden");
						if (typeof window.__initLightbox === "function") window.__initLightbox();
					}
				} catch(e) {
					loading.classList.add("hidden");
					console.error("[home memos]", e);
				}
			}

			document.addEventListener("DOMContentLoaded", initHomeMemos);
			document.addEventListener("astro:page-load", initHomeMemos);
		</script>
	</body>
</html>
