---
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import MomentsCard from "../../components/MomentsCard.astro";
import { SITE_TITLE } from "../../consts";
import { fetchAllMemos, type MemoV2 } from "../../lib/fetchMemos";

export async function getStaticPaths({ paginate }: { paginate: Function }) {
	const allMemos: MemoV2[] = await fetchAllMemos();
	// Sort by newest first (ISO date string comparison works correctly)
	allMemos.sort((a, b) => new Date(b.displayTime).getTime() - new Date(a.displayTime).getTime());
	return paginate(allMemos, { pageSize: 15 });
}

const { page } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-cn">
	<head>
		<BaseHead title={`碎片随笔 | ${SITE_TITLE}`} description="日常动态、碎片随笔和灵感记录" />
	</head>
	<body class="bg-white dark:bg-neutral-900 text-neutral-800 dark:text-neutral-200 transition-colors duration-300">
		<Header />
		<main class="mx-auto max-w-4xl px-4 py-10 relative font-body min-h-[max(calc(100vh-200px),600px)]">

			<!-- Page Header -->
			<!-- Background Asymmetric Element removed for ultra-clean Terminal aesthetics -->

			<div class="flex flex-col items-start gap-8 mb-16 mt-12 relative z-10 pl-4 md:pl-10 text-left">
				<!-- Red Vertical Stroke Accent -->
				<div class="absolute left-0 top-2 bottom-4 w-px bg-gradient-to-b from-[#bc152d] via-[#bc152d]/50 to-transparent shadow-[0_0_8px_rgba(188,21,45,0.4)]"></div>
				
				<div class="w-full">
					<span class="text-[#bc152d] font-body text-xs tracking-[0.3em] uppercase mb-8 block">Moments</span>
					<h1 class="font-headline text-4xl md:text-5xl font-bold tracking-widest mb-8 text-neutral-900 dark:text-neutral-100 leading-tight">
						<div class="flex items-center flex-wrap">碎片随笔<span class="animate-blink ml-1 font-mono text-[#bc152d]">_</span></div>
						<div class="text-neutral-400 dark:text-neutral-500 font-normal text-xl md:text-2xl mt-4 tracking-widest">日常动态、灵感与信号碎片</div>
					</h1>
				</div>
			</div>

			<!-- Active Tag Filter Banner -->
			<div id="active-tag-banner" class="hidden flex items-center justify-between pb-4 mb-8 border-b border-neutral-200 dark:border-neutral-800 relative z-20">
				<div class="flex items-center gap-3">
					<span class="text-sm font-mono text-neutral-400 dark:text-neutral-500 font-bold tracking-widest">QUERY //</span>
					<div id="active-tag-container"></div>
				</div>
				<a href="?" id="clear-filter-btn" class="text-sm font-mono text-neutral-400 dark:text-neutral-500 hover:text-[#bc152d] dark:hover:text-[#ffb3b1] transition-colors duration-200 no-underline tracking-widest uppercase">
					[ 清除 / Clear ]
				</a>
			</div>

			<!-- Memos List -->
			<section class="relative z-20 mt-8">
				{page.data.length > 0 ? (
					<div class="flex flex-col gap-8">
						{page.data.map((memo: MemoV2) => (
							<MomentsCard content={memo.content} displayTime={memo.displayTime} showFullDate={true} attachments={memo.attachments} location={memo.location} tags={memo.tags} />
						))}
					</div>
				) : (
					<div class="text-center py-16 text-neutral-400 dark:text-neutral-500">
						<p class="font-mono text-sm tracking-widest">// NO SIGNAL DETECTED</p>
						<p class="mt-2 text-xs tracking-wider">暂无公开动态，请稍后再试。</p>
					</div>
				)}
			</section>

			<!-- Pagination Navigator -->
			{page.lastPage > 1 && (
				<nav id="pagination-nav" class="flex items-center justify-between mt-16 pt-8 border-t border-neutral-200 dark:border-neutral-800 font-mono text-sm">
					<div>
						{page.url.prev ? (
							<a href={page.url.prev} class="inline-flex items-center gap-2 px-4 py-2 border border-neutral-900 dark:border-white text-neutral-900 dark:text-white hover:opacity-70 transition-opacity no-underline uppercase tracking-widest text-xs">
								<svg class="w-3 h-3 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
								上一页
							</a>
						) : (
							<span class="inline-flex items-center gap-2 px-4 py-2 border border-neutral-300 dark:border-neutral-700 text-neutral-300 dark:text-neutral-700 cursor-not-allowed uppercase tracking-widest text-xs">
								<svg class="w-3 h-3 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
								上一页
							</span>
						)}
					</div>

					<span class="text-neutral-500 dark:text-neutral-400 tracking-widest text-xs">
						[ {page.currentPage} / {page.lastPage} ]
					</span>

					<div>
						{page.url.next ? (
							<a href={page.url.next} class="inline-flex items-center gap-2 px-4 py-2 border border-neutral-900 dark:border-white text-neutral-900 dark:text-white hover:opacity-70 transition-opacity no-underline uppercase tracking-widest text-xs">
								下一页
								<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
							</a>
						) : (
							<span class="inline-flex items-center gap-2 px-4 py-2 border border-neutral-300 dark:border-neutral-700 text-neutral-300 dark:text-neutral-700 cursor-not-allowed uppercase tracking-widest text-xs">
								下一页
								<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
							</span>
						)}
					</div>
				</nav>
			)}

		</main>
		<Footer />

		<script>
			function initTagFilter() {
				const searchParams = new URLSearchParams(window.location.search);
				const activeTag = searchParams.get('tag');
				const banner = document.getElementById('active-tag-banner');
				const container = document.getElementById('active-tag-container');
				const cards = document.querySelectorAll('.moment-card');

				if (activeTag && banner && container) {
					banner.classList.remove('hidden');
					
					// Render active tag pill inside the banner
					container.innerHTML = `
						<a href="${window.location.pathname}" class="text-sm font-mono text-[#bc152d] dark:text-[#ffb3b1] bg-[#bc152d]/5 dark:bg-[#bc152d]/20 px-2 py-1 rounded-sm flex items-center gap-1 cursor-pointer no-underline hover:opacity-80 transition-opacity tracking-widest">
							[ ${activeTag} &times; ]
						</a>
					`;

					let visibleCount = 0;

					// Filter cards
					cards.forEach(card => {
						const tagsAttr = card.getAttribute('data-tags');
						if (tagsAttr) {
							const tagsList = tagsAttr.split(',');
							if (tagsList.includes(activeTag)) {
								card.classList.remove('hidden');
								visibleCount++;
								
								// Highlight the matching tag pill inside this card
								const tagPills = card.querySelectorAll('a[data-tag]');
								tagPills.forEach(pill => {
									if (pill.getAttribute('data-tag') === activeTag) {
										pill.classList.add('bg-[#bc152d]/10', 'dark:bg-[#ffb3b1]/10');
										// Insert X character before the closing bracket if missing
										if (!pill.querySelector('.clear-icon')) {
											const closingBracket = pill.lastElementChild;
											if (closingBracket) {
												closingBracket.insertAdjacentHTML('beforebegin', '<span class="clear-icon mx-1">&times;</span>');
											}
										}
										// change href to clear filter
										pill.setAttribute('href', window.location.pathname);
									}
								});
							} else {
								card.classList.add('hidden');
							}
						} else {
							card.classList.add('hidden');
						}
					});

					// If no cards are visible on this page after filtering, we could show a message, but for now just let it be empty or hide pagination.
				}

				// Persist URL search params (e.g. ?tag=xxx) to pagination links
				const paginationNav = document.getElementById('pagination-nav');
				if (paginationNav && window.location.search) {
					const links = paginationNav.querySelectorAll('a[href]');
					links.forEach(linkObj => {
						const link = linkObj as HTMLAnchorElement;
						try {
							const url = new URL(link.href);
							const currentParams = new URLSearchParams(window.location.search);
							for (const [key, value] of currentParams) {
								url.searchParams.set(key, value);
							}
							link.href = url.toString();
						} catch (e) {
							// Ignore invalid URLs
						}
					});
				}
			}

			// Run on initial load
			document.addEventListener('DOMContentLoaded', initTagFilter);
			// Support Astro View Transitions
			document.addEventListener('astro:page-load', initTagFilter);
		</script>
	</body>
</html>
